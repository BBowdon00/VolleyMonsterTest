# ── Frontend (safe to expose to browser) ──────────────────────────────────────
VITE_STRIPE_PUBLISHABLE_KEY=pk_test_...

# Optional — leave blank to disable in dev
VITE_SENTRY_DSN=

# ── Netlify Functions (never bundled into frontend) ───────────────────────────
# NETLIFY_DB_URL is auto-injected by Netlify at build and runtime.
# For local dev: run `netlify database init` then `netlify dev` — it sets the var automatically.

STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

RESEND_API_KEY=re_...
EMAIL_FROM=info@volleymonster.com

PUBLIC_SITE_URL=http://localhost:8888

# Set to 'true' to skip Stripe and auto-confirm registrations (dev/testing only)
STRIPE_BYPASS=false

# Optional
SENTRY_DSN=
