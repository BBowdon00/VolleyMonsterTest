# Copy to /opt/volleymonster/.env on the droplet and fill in values.

# GHCR image owner (your GitHub username or org, lowercase) and image tag.
GHCR_OWNER=your-github-username
TAG=latest

# Postgres
POSTGRES_PASSWORD=changeme

# Stripe (use sk_live_/whsec_live_ on production)
STRIPE_SECRET_KEY=sk_live_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx

# Email (Resend)
RESEND_API_KEY=re_xxx
EMAIL_FROM=Volley Monster <noreply@volleymonster.com>

# Public site URL (no trailing slash)
PUBLIC_SITE_URL=https://volleymonster.com

# Admin token (random secret; required for /admin to work)
ADMIN_TOKEN=generate-a-long-random-string
